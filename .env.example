# Server-side only — never prefix with VITE_, or it gets bundled into the
# client JS and exposed to anyone who opens devtools. Read by vite.config.ts
# (local dev proxy) and by api/anthropic/[...path].ts (Vercel deployment).
# On Vercel, set this in Project Settings > Environment Variables instead of
# committing it here.
ANTHROPIC_API_KEY=

# Non-secret feature flag — safe to bundle into the client. Controls whether
# the app attempts live Claude Vision analysis (via /api/anthropic) or falls
# back to the heuristic mock generator.
VITE_ENABLE_LIVE_ANALYSIS=true
